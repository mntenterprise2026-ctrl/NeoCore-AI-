<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Base deep violet gradient background -->
    <path
        android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:color="#FF310D69" android:offset="0.0" />
                <item android:color="#FF1A0536" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Translucent neon glass wave 1 -->
    <path
        android:pathData="M 0,60 C 20,40 40,80 60,50 C 80,20 100,50 108,40 L 108,108 L 0,108 Z"
        android:fillAlpha="0.18">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="40"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:color="#FF8B5CF6" android:offset="0.0" />
                <item android:color="#00EC4899" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Translucent liquid glass overlay wave 2 (diagonal flow) -->
    <path
        android:pathData="M-10,30 C 20,10 50,60 80,42 C 100,32 110,60 120,50 L 120,120 L-10,120 Z"
        android:fillAlpha="0.25">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="20"
                android:endX="110"
                android:endY="110"
                android:type="linear">
                <item android:color="#FFEC4899" android:offset="0.0" />
                <item android:color="#003B82F6" android:offset="0.8" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top glossy glass reflection highlight -->
    <path
        android:pathData="M 5,5 Q 54,30 103,5 L 108,0 L 0,0 Z"
        android:fillAlpha="0.12">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="54"
                android:startY="0"
                android:endX="54"
                android:endY="30"
                android:type="linear">
                <item android:color="#FFFFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>
    
</vector>
